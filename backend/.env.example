# 数据库配置模板
DB_HOST=127.0.0.1
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=nav_site
DB_PORT=3306

# JWT
JWT_SECRET_KEY=change-me

# Redis 可选；未启动时本地演示会降级
REDIS_URL=redis://localhost:6379/0

# 邮件验证码
# 本地演示建议 false：验证码会打印在 Flask 后端控制台
MAIL_ENABLED=false
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@example.com
SMTP_AUTH_CODE=your_smtp_authorization_code
SMTP_USE_SSL=true
MAIL_FROM_NAME=智汇导航
